{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "types": ["jest", "node"]
  },
  "include": ["src/**/*.js", "tests/**/*.js", "tests/**/*.ts", "src/**/*.ts"]
}
